# Bot token from Discord Developer Portal → Bot → Reset Token / Copy
DISCORD_TOKEN=

# Application ID (same as "Client ID" on the OAuth2 page)
CLIENT_ID=

# Optional: register slash commands to one guild only (instant updates while testing).
# Leave unset to register commands globally (slow propagation, up to ~1 hour).
# GUILD_ID=

# Optional: IANA timezone when /time has no timezone option and the server has no /config timezone set (also used in DMs).
# Example: America/New_York
# DEFAULT_TIMEZONE=
